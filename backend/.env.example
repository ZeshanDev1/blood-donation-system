# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/blood-donor-db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL(s) for CORS — single origin or comma-separated list.
# Any *.vercel.app preview domain is also allowed automatically.
# Production example:
#   FRONTEND_URL=https://qbds.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Default admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!

# ─────────────────────────────────────────────
# Cloudinary (image uploads). If unset, uploads fall back to local disk.
# Use EITHER the single URL form…
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# …OR the three separate values:
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
