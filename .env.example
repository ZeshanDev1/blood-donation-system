# ─────────────────────────────────────────────
# Frontend (Next.js) Environment Variables
# ─────────────────────────────────────────────

# Base URL of the deployed backend API (Node.js on Render / Railway).
# Local development:
#   NEXT_PUBLIC_API_URL=http://localhost:5000
# Production example:
#   NEXT_PUBLIC_API_URL=https://qbds-api.onrender.com
#
# NOTE: This variable is inlined into the browser bundle at build time,
# so it MUST be set in the Vercel project settings before building.
NEXT_PUBLIC_API_URL=http://localhost:5000
